---
import { Image } from 'astro:assets';
import github from "@/content/images/github.png";
import telegram from "@/content/images/telegram.png";
import email from "@/content/images/email.png";
import Heading from "@/components/Heading.astro";

const links : { url: string, image: ImageMetadata, name: string }[] = [
    {
        url: 'https://github.com/MindHardt',
        image: github,
        name: 'Github'
    },
    {
        url: 'https://t.me/un1ver5e',
        image: telegram,
        name: 'Telegram'
    },
    {
        url: 'mailto:igorbabin2002@gmail.com',
        image: email,
        name: 'Email'
    }
]

---

<section>
    <Heading level={2}>Ссылки на меня</Heading>
    <div class="flex flex-col gap-1">
        {links.map(l =>
                <a href={l.url} class="flex flex-row items-center gap-2 p-2 elevated text-foreground">
                    <Image src={l.image} alt='' width={40} height={40} class="size-8" />
                    <span class="font-semibold">{l.name}</span>
                </a>)}
    </div>
</section>
